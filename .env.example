# ── Supabase (web app) ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── Postgres (research worker connects directly) ──────────────────────
# Local supabase default: postgresql://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=

# ── Discovery / enrichment providers (optional; demo mode works without) ──
BRAVE_SEARCH_API_KEY=
HUNTER_API_KEY=

# ── AI provider (optional; app works without) ─────────────────────────
# "anthropic" or "openai"; blank disables AI analysis.
AI_PROVIDER=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=

# ── Crawler identity ──────────────────────────────────────────────────
CRAWLER_USER_AGENT=LeadResearchBot/0.1 (+contact below)
CRAWLER_CONTACT_EMAIL=
APP_BASE_URL=http://localhost:3000

# ── Demo mode: use fixture search results and fixture websites ────────
DEMO_MODE=true

# ── Worker ────────────────────────────────────────────────────────────
WORKER_ID=worker-1
WORKER_POLL_SECONDS=5
