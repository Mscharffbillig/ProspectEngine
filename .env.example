# ── Neon Postgres ─────────────────────────────────────────────────────
# Pooled connection string (host contains "-pooler") — used by the web app
# and the research worker at runtime.
DATABASE_URL=
# Direct (non-pooled) connection string — used for Drizzle migrations.
DIRECT_DATABASE_URL=

# ── Neon Auth (Stack) — from Neon Console → Auth ──────────────────────
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
# Server-side only. Never expose to the browser.
STACK_SECRET_SERVER_KEY=

# ── Discovery / enrichment providers (optional; demo mode works without) ──
BRAVE_SEARCH_API_KEY=
HUNTER_API_KEY=

# ── AI provider (optional; app works without) ─────────────────────────
# "anthropic" or "openai"; blank disables AI analysis.
AI_PROVIDER=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AI_MODEL=

# ── Crawler identity ──────────────────────────────────────────────────
CRAWLER_USER_AGENT=LeadResearchBot/0.1 (+contact below)
CRAWLER_CONTACT_EMAIL=
APP_BASE_URL=http://localhost:3000

# ── Demo mode: use fixture search results and fixture websites ────────
DEMO_MODE=true

# ── Worker ────────────────────────────────────────────────────────────
WORKER_ID=worker-1
WORKER_POLL_SECONDS=5
